rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || hasRole('admin');
      allow delete: if hasRole('admin');
    }

    // Creators collection
    match /creators/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || hasRole('admin');
    }

    // Brands collection
    match /brands/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || hasRole('admin');
    }

    // Campaigns collection
    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow create: if hasRole('brand') || hasRole('admin');
      allow update: if isSignedIn() && (resource.data.brandId == request.auth.uid || hasRole('admin'));
      allow delete: if hasRole('admin');
    }

    // Applications collection
    match /applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || 
        resource.data.brandId == request.auth.uid || 
        hasRole('admin')
      );
      allow create: if hasRole('creator');
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || 
        resource.data.brandId == request.auth.uid || 
        hasRole('admin')
      );
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if hasRole('admin');
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
